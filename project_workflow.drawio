    <mxCell id="2" value="&lt;div style='font-size:22px;font-weight:bold;color:#1a237e;'&gt;IVC Project — Complete End-to-End Workflow&lt;/div&gt;&lt;div style='font-size:13px;color:#555;margin-top:3px;'&gt;Boston University CS &amp;nbsp;·&amp;nbsp; Weakly-Supervised Violence Detection in Surveillance Video &amp;nbsp;·&amp;nbsp; Srinivasa Sai Chava&lt;/div&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="80" y="15" width="1640" height="65" as="geometry" />
    </mxCell>
    <mxCell id="3" value="📌  PHASE 1 — Problem Definition" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dde1ff;strokeColor=#3730a3;strokeWidth=3;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingTop=8;spacingLeft=14;fontColor=#1e1b4b;" vertex="1" parent="1">
      <mxGeometry x="80" y="95" width="1640" height="125" as="geometry" />
    </mxCell>
    <mxCell id="4" value="&lt;b&gt;Research Question&lt;/b&gt;&lt;br/&gt;Can we detect, classify &amp;amp; temporally&lt;br/&gt;localize violence events using only&lt;br/&gt;video-level weak labels?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#4338ca;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="100" y="143" width="500" height="65" as="geometry" />
    </mxCell>
    <mxCell id="5" value="&lt;b&gt;Core Approach&lt;/b&gt;&lt;br/&gt;Multiple Instance Learning (MIL) +&lt;br/&gt;Temporal Refinement + Boundary prediction&lt;br/&gt;with frozen backbone features" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#4338ca;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="650" y="143" width="500" height="65" as="geometry" />
    </mxCell>
    <mxCell id="6" value="&lt;b&gt;Key Innovation&lt;/b&gt;&lt;br/&gt;Replace I3D (2017) backbone with&lt;br/&gt;VideoMAE-B (2022) masked autoencoder&lt;br/&gt;— same architecture, better features" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#4338ca;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="1200" y="143" width="500" height="65" as="geometry" />
