    <mxCell id="52" value="📊  PHASE 7 — Results  (Mean ± Std, 3 Seeds — VideoMAE-B dominates every metric)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#15803d;strokeWidth=3;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingTop=8;spacingLeft=14;fontColor=#14532d;" vertex="1" parent="1">
