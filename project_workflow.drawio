    <mxCell id="32" value="🧠  PHASE 4 — Model Architecture  (Shared · 1.9M trainable params · 86M frozen)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;strokeWidth=3;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingTop=8;spacingLeft=14;fontColor=#4c1d95;" vertex="1" parent="1">
      <mxGeometry x="80" y="760" width="1640" height="220" as="geometry" />
    </mxCell>
    <mxCell id="33" value="&lt;b&gt;MIL Anomaly Scorer&lt;/b&gt;&lt;br/&gt;2-layer MLP · σ(W₃ Dropout(ReLU(…)))&lt;br/&gt;s_t ∈ [0,1] per segment&lt;br/&gt;ℒ_MIL ranking loss&lt;br/&gt;&lt;i&gt;1.1M params&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="100" y="812" width="370" height="150" as="geometry" />
    </mxCell>
    <mxCell id="37" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=1.8;strokeColor=#7c3aed;endArrow=block;endFill=1;fontSize=10;" edge="1" source="33" target="34" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="34" value="&lt;b&gt;Event Classifier&lt;/b&gt;&lt;br/&gt;7-class softmax head&lt;br/&gt;Top-k pseudo-positive segments&lt;br/&gt;Inv-freq weighted CE loss&lt;br/&gt;&lt;i&gt;0.3M params&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="510" y="812" width="370" height="150" as="geometry" />
    </mxCell>
    <mxCell id="38" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=1.8;strokeColor=#7c3aed;endArrow=block;endFill=1;fontSize=10;" edge="1" source="34" target="35" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="35" value="&lt;b&gt;Temporal Refinement (TRN)&lt;/b&gt;&lt;br/&gt;Transformer encoder&lt;br/&gt;Multi-head self-attention over {f_t}&lt;br/&gt;Refined scores s̃_t&lt;br/&gt;&lt;i&gt;0.4M params&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="920" y="812" width="370" height="150" as="geometry" />
    </mxCell>
    <mxCell id="39" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeWidth=1.8;strokeColor=#7c3aed;endArrow=block;endFill=1;fontSize=10;" edge="1" source="35" target="36" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="36" value="&lt;b&gt;Boundary Head&lt;/b&gt;&lt;br/&gt;b_t = σ(W_b[h̃_t; h̃_{t+1}; |s̃_t − s̃_{t+1}|])&lt;br/&gt;Boundary consistency loss ℒ_bnd&lt;br/&gt;Predicts event start/end&lt;br/&gt;&lt;i&gt;0.1M params&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="1330" y="812" width="370" height="150" as="geometry" />
    </mxCell>
    <mxCell id="31" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeWidth=2.5;strokeColor=#555555;fontSize=11;" edge="1" source="14" target="32" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>
    <mxCell id="41" value="🏋️  PHASE 5 — Training Recipe  (3 Innovations beyond vanilla RTFM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;strokeWidth=3;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingTop=8;spacingLeft=14;fontColor=#78350f;" vertex="1" parent="1">
      <mxGeometry x="80" y="1010" width="1640" height="190" as="geometry" />
    </mxCell>
    <mxCell id="42" value="&lt;b&gt;① Inverse-Frequency&lt;br/&gt;Class Weights&lt;/b&gt;&lt;br/&gt;w_c = N / (C · n_c)&lt;br/&gt;Normal: w ≈ 0.06&lt;br/&gt;Shooting: w ≈ 1.83&lt;br/&gt;Counters 10:1 imbalance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="100" y="1058" width="375" height="130" as="geometry" />
    </mxCell>
    <mxCell id="43" value="&lt;b&gt;② Confidence Threshold&lt;/b&gt;&lt;br/&gt;τ = 0.30&lt;br/&gt;Pseudo-positive segments&lt;br/&gt;accepted only if s_t ≥ τ&lt;br/&gt;Reduces noisy label training&lt;br/&gt;in early epochs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="505" y="1058" width="375" height="130" as="geometry" />
    </mxCell>
    <mxCell id="44" value="&lt;b&gt;③ Cosine Annealing LR&lt;/b&gt;&lt;br/&gt;η: 10⁻⁴ → 10⁻⁶&lt;br/&gt;T_max = 40 epochs&lt;br/&gt;No warm restarts&lt;br/&gt;Avoids step-decay oscillations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="910" y="1058" width="375" height="130" as="geometry" />
    </mxCell>
    <mxCell id="45" value="&lt;b&gt;④ Multi-Seed Training&lt;/b&gt;&lt;br/&gt;Seeds: 42 · 123 · 456&lt;br/&gt;40 epochs each&lt;br/&gt;AdamW · batch 32&lt;br/&gt;Dropout 0.5 · WD 10⁻⁴" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#d97706;fontSize=11;verticalAlign=middle;align=center;" vertex="1" parent="1">
      <mxGeometry x="1315" y="1058" width="375" height="130" as="geometry" />
    </mxCell>
