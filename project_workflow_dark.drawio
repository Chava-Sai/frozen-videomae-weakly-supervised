        <mxCell id="38" value="&lt;b&gt;&lt;font color=&#39;#ffffff&#39; style=&#39;font-size:13px&#39;&gt;Trained Model&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font color=&#39;#9ca3af&#39; style=&#39;font-size:11px&#39;&gt;Best checkpoint (seed 123)&lt;br/&gt;AUC = 93.4% peak epoch&lt;br/&gt;40-epoch training&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#052e1a;strokeColor=#059669;strokeWidth=2;fontColor=#ffffff;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" parent="1" vertex="1">
