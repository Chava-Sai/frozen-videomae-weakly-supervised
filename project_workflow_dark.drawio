        <mxCell id="37" value="&lt;b&gt;&lt;font color=&#39;#10b981&#39; style=&#39;font-size:15px&#39;&gt;&lt;font color=&#39;#ffffff&#39;&gt;  ③  &lt;/font&gt;INFERENCE &amp; EVALUATION — UCF-Crime Violence Subset&lt;/font&gt;&lt;/b&gt;" style="swimlane;startSize=38;rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a1a;strokeColor=#10b981;strokeWidth=3;fontColor=#10b981;fontSize=15;fontStyle=1;swimlaneLine=0;" parent="1" vertex="1">
          <mxGeometry x="1150" y="620" width="1230" height="1060" as="geometry" />
