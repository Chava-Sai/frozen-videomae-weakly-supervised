        <mxCell id="22" value="&lt;b&gt;&lt;font color=&#39;#8b5cf6&#39; style=&#39;font-size:15px&#39;&gt;&lt;font color=&#39;#ffffff&#39;&gt;  ②  &lt;/font&gt;MODEL ARCHITECTURE — 1.9M Trainable Parameters · 86M Frozen&lt;/font&gt;&lt;/b&gt;" style="swimlane;startSize=38;rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a1a;strokeColor=#8b5cf6;strokeWidth=3;fontColor=#8b5cf6;fontSize=15;fontStyle=1;swimlaneLine=0;" parent="1" vertex="1">
          <mxGeometry x="20" y="620" width="1110" height="1060" as="geometry" />
        </mxCell>
        <mxCell id="23" value="&lt;b&gt;&lt;font color=&#39;#ffffff&#39; style=&#39;font-size:13px&#39;&gt;MIL Anomaly Scorer&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font color=&#39;#9ca3af&#39; style=&#39;font-size:11px&#39;&gt;s_t = σ(W₃ Dropout(ReLU(W₂ ReLU(W₁ f_t))))&lt;br/&gt;Video score: s_vid = max_t(s_t)&lt;br/&gt;ℒ_MIL ranking loss · anom/norm pairs&lt;br/&gt;1.1 M params&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0e3f;strokeColor=#7c3aed;strokeWidth=2;fontColor=#ffffff;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" parent="1" vertex="1">
          <mxGeometry x="40" y="730" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="24" value="&lt;b&gt;&lt;font color=&#39;#ffffff&#39; style=&#39;font-size:13px&#39;&gt;Event Classifier&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font color=&#39;#9ca3af&#39; style=&#39;font-size:11px&#39;&gt;7-class softmax · top-k pseudo segs&lt;br/&gt;Confidence filter τ = 0.30&lt;br/&gt;Inv-freq weighted CE loss&lt;br/&gt;0.3 M params&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0e3f;strokeColor=#7c3aed;strokeWidth=2;fontColor=#ffffff;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" parent="1" vertex="1">
          <mxGeometry x="400" y="730" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="25" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#8b5cf6;strokeWidth=1.8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=block;endFill=1;fontColor=#ffffff;fontSize=10;" parent="1" source="23" target="24" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="26" value="&lt;b&gt;&lt;font color=&#39;#ffffff&#39; style=&#39;font-size:13px&#39;&gt;Temporal Refinement (TRN)&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font color=&#39;#9ca3af&#39; style=&#39;font-size:11px&#39;&gt;Transformer encoder over {f_t + PE_t}&lt;br/&gt;Multi-head self-attention&lt;br/&gt;Refined scores s̃_t  and  h̃_t&lt;br/&gt;0.4 M params&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#151040;strokeColor=#6366f1;strokeWidth=2;fontColor=#ffffff;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" parent="1" vertex="1">
          <mxGeometry x="40" y="940" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="27" value="&lt;b&gt;&lt;font color=&#39;#ffffff&#39; style=&#39;font-size:13px&#39;&gt;Boundary Head&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font color=&#39;#9ca3af&#39; style=&#39;font-size:11px&#39;&gt;b_t = σ(W_b [h̃_t ; h̃_{t+1} ; |s̃_t − s̃_{t+1}|])&lt;br/&gt;Boundary consistency loss ℒ_bnd&lt;br/&gt;Event start / end confidence&lt;br/&gt;0.1 M params&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#151040;strokeColor=#6366f1;strokeWidth=2;fontColor=#ffffff;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" parent="1" vertex="1">
          <mxGeometry x="400" y="940" width="320" height="160" as="geometry" />
        </mxCell>
        <mxCell id="28" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#8b5cf6;strokeWidth=1.8;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=block;endFill=1;fontColor=#ffffff;fontSize=10;" parent="1" source="26" target="27" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="29" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#8b5cf6;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontColor=#ffffff;fontSize=10;" parent="1" source="24" target="27" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="30" value="&lt;b&gt;&lt;font color=&#39;#ffffff&#39; style=&#39;font-size:13px&#39;&gt;Full Training Objective&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font color=&#39;#9ca3af&#39; style=&#39;font-size:11px&#39;&gt;ℒ = ℒ_MIL + λ₁ℒ_cls + λ₂ℒ_bnd + λ₃ℒ_smooth&lt;br/&gt;ℒ_smooth = Σ(s̃_t − s̃_{t-1})²&lt;br/&gt;λ₁=0.5 · λ₂=0.3 · λ₃=0.1&lt;br/&gt;AdamW · lr=1e-4 · WD=1e-4 · Dropout=0.5 · Batch=32&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1e1e1e;strokeColor=#6b7280;strokeWidth=2;fontColor=#ffffff;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" parent="1" vertex="1">
          <mxGeometry x="40" y="1155" width="680" height="160" as="geometry" />
        </mxCell>
        <mxCell id="31" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6b7280;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontColor=#ffffff;fontSize=10;" parent="1" source="27" target="30" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="32" value="&lt;b&gt;&lt;font color=&#39;#ffffff&#39; style=&#39;font-size:12px&#39;&gt;① Inv-Freq Weights&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font color=&#39;#9ca3af&#39; style=&#39;font-size:10px&#39;&gt;w_c = N / (C · n_c)&lt;br/&gt;Normal: w ≈ 0.06&lt;br/&gt;Shooting: w ≈ 1.83&lt;br/&gt;Counters 10:1 imbalance&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0e3f;strokeColor=#7c3aed;strokeWidth=2;fontColor=#ffffff;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;" parent="1" vertex="1">
          <mxGeometry x="40" y="1370" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="33" value="&lt;b&gt;&lt;font color=&#39;#ffffff&#39; style=&#39;font-size:12px&#39;&gt;② Conf. Threshold&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font color=&#39;#9ca3af&#39; style=&#39;font-size:10px&#39;&gt;τ = 0.30&lt;br/&gt;Filter noisy pseudo-&lt;br/&gt;positive segments&lt;br/&gt;in early epochs&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0e3f;strokeColor=#7c3aed;strokeWidth=2;fontColor=#ffffff;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;" parent="1" vertex="1">
          <mxGeometry x="295" y="1370" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="34" value="&lt;b&gt;&lt;font color=&#39;#ffffff&#39; style=&#39;font-size:12px&#39;&gt;③ Cosine Anneal LR&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font color=&#39;#9ca3af&#39; style=&#39;font-size:10px&#39;&gt;η: 1e-4 → 1e-6&lt;br/&gt;T_max = 40 epochs&lt;br/&gt;No warm restarts&lt;br/&gt;No step-decay spikes&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0e3f;strokeColor=#7c3aed;strokeWidth=2;fontColor=#ffffff;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;" parent="1" vertex="1">
          <mxGeometry x="550" y="1370" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="35" value="&lt;b&gt;&lt;font color=&#39;#ffffff&#39; style=&#39;font-size:12px&#39;&gt;④ 3-Seed Training&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;font color=&#39;#9ca3af&#39; style=&#39;font-size:10px&#39;&gt;Seeds: 42 · 123 · 456&lt;br/&gt;40 epochs each&lt;br/&gt;Report mean ± std&lt;br/&gt;Reproducibility check&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a0e3f;strokeColor=#7c3aed;strokeWidth=2;fontColor=#ffffff;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;" parent="1" vertex="1">
          <mxGeometry x="805" y="1370" width="240" height="160" as="geometry" />
        </mxCell>
        <mxCell id="36" value="Total trainable: 1.9M  ·  Frozen backbone: 86M  ·  PyTorch 2.1  ·  Transformers 5.5.4  ·  BU SCC A100" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontColor=#9ca3af;fontSize=11;fontStyle=0;whiteSpace=wrap;" parent="1" vertex="1">
